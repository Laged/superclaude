# Ghostty configuration — recommended terminal for superclaude projects
# Copy to: ~/.config/ghostty/config (Linux/macOS)
# Install: https://ghostty.org/download
#
# macOS:  brew install ghostty
# Linux:  Available in nixpkgs (nix profile install nixpkgs#ghostty)
# WSL:    Install on Windows side from ghostty.org

# Font
font-family = JetBrains Mono
font-size = 14

# Theme
theme = catppuccin-mocha

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = auto
confirm-close-surface = false

# Shell integration
shell-integration = zsh

# Cursor
cursor-style = bar
cursor-style-blink = false

# Scrollback
scrollback-limit = 10000

# Clipboard
copy-on-select = clipboard
